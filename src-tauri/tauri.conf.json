{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevToolbox",
  "version": "1.1.0",
  "identifier": "com.devtoolbox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "开发者工具箱 DevToolbox",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["zh-CN"]
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
